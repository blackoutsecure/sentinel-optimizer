---
import { siteLinks, externalSources, repoLinks } from "../lib/links";
import { APP_VERSION, BUILD_DATE } from "../lib/version";
import { BRAND } from "../lib/brand";

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
const site = siteLinks(base);
const sources = externalSources();
const repo = repoLinks();

// Format BUILD_DATE as a short, readable date.
let buildDateLabel = "";
let buildDateIso = "";
try {
  const d = new Date(BUILD_DATE);
  if (!Number.isNaN(d.getTime())) {
    buildDateIso = d.toISOString();
    buildDateLabel = d.toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    });
  }
} catch {
  // ignore — buildDateLabel stays empty and we skip the badge
}
---

<footer class="footer" role="contentinfo">
  <div class="container footer__grid">
    <div class="footer__col">
      <h4>{BRAND.name}</h4>
      <p>
        An independent community SIEM cost analyzer for Microsoft Sentinel. Built with Astro,
        MIT-licensed.
      </p>
      <p><strong>Not affiliated with or endorsed by Microsoft Corporation.</strong></p>
    </div>
    <div class="footer__col">
      <h4>Site</h4>
      <ul>
        {
          site.map((l: any) => (
            <li>
              <a href={l.href}>{l.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="footer__col">
      <h4>Resources</h4>
      <ul>
        {
          sources.map((l: any) => (
            <li>
              <a href={l.href} target="_blank" rel="noopener">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="footer__col">
      <h4>Repo</h4>
      <ul>
        {
          repo.map((l: any) => (
            <li>
              <a href={l.href} target="_blank" rel="noopener">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
  <div class="container footer__bottom">
    <span
      >&copy; {year}
      {BRAND.owner} · MIT Licensed · <span class="footer__version">{APP_VERSION}</span>{
        buildDateLabel && (
          <>
            {" · "}
            <span class="footer__build-date">
              Updated <time datetime={buildDateIso}>{buildDateLabel}</time>
            </span>
          </>
        )
      }</span
    >
    <span
      >Microsoft, Azure, Sentinel, Defender, and Copilot are trademarks of Microsoft Corporation.
      Used in nominative descriptive sense only.</span
    >
  </div>
</footer>

<style>
  .footer {
    background: var(--bg);
    border-top: 1px solid var(--border);
    margin-top: 6rem;
    padding: 3.5rem 0 2rem;
    font-size: 0.9rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer__col h4 {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 1rem;
    color: var(--text);
  }

  .footer__col p {
    margin: 0 0 0.8rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .footer__col p strong {
    color: var(--text);
  }

  .footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__col a {
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.2s ease;
    font-size: 0.85rem;
  }

  .footer__col a:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .footer__bottom span {
    line-height: 1.5;
  }

  .footer__version {
    font-family: var(--font-mono);
    color: var(--accent);
  }

  .footer__build-date {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .footer__bottom {
      gap: 0.8rem;
      font-size: 0.75rem;
    }
  }
</style>
